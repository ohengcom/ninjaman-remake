{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:godot:web",
  "outputDirectory": "godot/build/web",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!index\\.(wasm|pck|js|png|svg)|favicon.ico|robots.txt).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.wasm",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/wasm"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.pck",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
